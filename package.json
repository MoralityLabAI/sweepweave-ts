{
  "name": "sweepweave-ts",
  "private": true,
  "version": "0.1.0",
  "description": "Sweepweave desktop app and renderer",
  "author": "MoralityLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoralityLab/sweepweave-ts.git"
  },
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node tools/electron-dev.mjs",
    "dev:renderer": "vite",
    "build": "tsc && vite build",
    "build:renderer": "vite build",
    "pack:win": "npm run build:renderer && electron-builder --win nsis portable",
    "pack:linux": "npm run build:renderer && electron-builder --linux AppImage tar.gz",
    "pack:mac": "npm run build:renderer && electron-builder --mac dmg zip",
    "pack:all": "npm run build:renderer && electron-builder -wml",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "org.moralitylab.sweepweave",
    "productName": "Sweepweave",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "electron": "^36.9.1",
    "electron-builder": "^26.0.12",
    "jsdom": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "three": "^0.182.0"
  }
}
